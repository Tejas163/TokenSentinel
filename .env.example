# =============================================================================
# TokenSentinel Environment Variables
# =============================================================================
# Copy this file to .env and customize for your environment.
# Docker Compose reads .env automatically if placed at the project root
# (or alongside the compose file). All variables are optional — defaults
# work for local development without auth.
# =============================================================================

# ---------------------------------------------------------------------------
# Redis (all services)
# ---------------------------------------------------------------------------
# REDIS_ADDR=localhost:6379          # go-router / cost-dashboard
# REDIS_URL=redis://127.0.0.1:6379  # rust-proxy / erlang-monitor
# REDIS_PASSWORD=                   # unset = no auth

# ---------------------------------------------------------------------------
# PostgreSQL (cost-dashboard only)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cost_dashboard?sslmode=disable

# ---------------------------------------------------------------------------
# Auth (go-router + cost-dashboard)
# ---------------------------------------------------------------------------
# Set the same value on both services. All routes except /health and
# /metrics require X-Api-Key or Authorization: Bearer <key>.
# Leave unset to disable auth.
AUTH_API_KEY=dev-key-123

# ---------------------------------------------------------------------------
# Budget-aware routing (go-router only)
# ---------------------------------------------------------------------------
# Default team name for cost records when X-Team-Name header is absent.
# BUDGET_TEAM_NAME=engineering

# ---------------------------------------------------------------------------
# Cost digest / Slack-Webhook (cost-dashboard only)
# ---------------------------------------------------------------------------
# DIGEST_WEBHOOK_URL=https://hooks.slack.com/services/...
# DIGEST_SCHEDULE=24h

# ---------------------------------------------------------------------------
# Upstream routing (rust-proxy only)
# ---------------------------------------------------------------------------
# GO_ROUTER_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Ports (cost-dashboard only)
# ---------------------------------------------------------------------------
# PORT=3001
